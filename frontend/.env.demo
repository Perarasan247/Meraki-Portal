# Config for the shareable single-file UI demo (`npm run build:demo`).
# No backend / Supabase — auth is bypassed and portals are browsable via the
# on-screen Preview switcher. Never use these settings for a real deployment.
VITE_SUPABASE_URL=https://demo.supabase.co
VITE_SUPABASE_ANON_KEY=demo-anon-key
VITE_API_BASE_URL=
VITE_DEV_BYPASS_AUTH=true
VITE_USE_HASH_ROUTER=true
