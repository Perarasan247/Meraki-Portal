# Copy to frontend/.env.production.local on the VPS before `npm run build`.
# Vite bakes these into the build, so they must be set BEFORE building.
#
# On the VPS, /api is same-origin (nginx proxies it), so use a relative path —
# no api subdomain, no CORS.

VITE_SUPABASE_URL=https://ktnsbslqynaspfngsdoi.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=/api
VITE_DEV_BYPASS_AUTH=false
