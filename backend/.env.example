# Supabase project settings
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Same secret configured on the Supabase JWT settings page — used to verify
# incoming access tokens locally without a round-trip to Supabase.
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# AI Reports Assistant (optional — leave blank to serve a stub response)
ANTHROPIC_API_KEY=
